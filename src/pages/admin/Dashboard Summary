<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Management Dashboard</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
    <style>
        :root {
            --primary-color: #2c3e50;
            --secondary-color: #34495e;
            --accent-color: #3498db;
            --text-light: #ecf0f1;
            --bg-light: #f4f7f6;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            display: flex;
            background-color: var(--bg-light);
            height: 100vh;
        }

        /* Sidebar Styling */
        .sidebar {
            width: 260px;
            background-color: var(--primary-color);
            color: var(--text-light);
            display: flex;
            flex-direction: column;
            padding: 20px 0;
            transition: all 0.3s;
        }

        .sidebar h2 {
            text-align: center;
            margin-bottom: 30px;
            font-size: 1.5rem;
            color: var(--accent-color);
        }

        .nav-item {
            padding: 15px 25px;
            cursor: pointer;
            display: flex;
            align-items: center;
            transition: 0.2s;
            border-left: 4px solid transparent;
        }

        .nav-item:hover {
            background-color: var(--secondary-color);
        }

        .nav-item.active {
            background-color: var(--secondary-color);
            border-left: 4px solid var(--accent-color);
        }

        .nav-item i {
            margin-right: 15px;
            width: 20px;
        }

        /* Content Area */
        .main-content {
            flex: 1;
            padding: 30px;
            overflow-y: auto;
        }

        .tab-content {
            display: none;
            animation: fadeIn 0.4s ease;
        }

        .tab-content.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Header UI */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            border-bottom: 2px solid #ddd;
            padding-bottom: 10px;
        }

        /* Placeholder Cards for Dashboard */
        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .card {
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .card h3 { font-size: 0.9rem; color: #7f8c8d; }
        .card p { font-size: 1.8rem; font-weight: bold; margin-top: 10px; }

        table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        th, td {
            padding: 15px;
            text-align: left;
            border-bottom: 1px solid #eee;
        }

        th { background-color: var(--accent-color); color: white; }
    </style>
</head>
<body>

    <div class="sidebar">
        <h2>Admin Portal</h2>
        <div class="nav-item active" onclick="openTab(event, 'dashboard')"><i class="fas fa-chart-line"></i> Summary Dashboard</div>
        <div class="nav-item" onclick="openTab(event, 'preschool')"><i class="fas fa-school"></i> Preschool</div>
        <div class="nav-item" onclick="openTab(event, 'summercamp')"><i class="fas fa-campground"></i> Summer Camp</div>
        <div class="nav-item" onclick="openTab(event, 'investment')"><i class="fas fa-piggy-bank"></i> Investment</div>
        <div class="nav-item" onclick="openTab(event, 'expenses')"><i class="fas fa-wallet"></i> Expenses</div>
        <div class="nav-item" onclick="openTab(event, 'employees')"><i class="fas fa-users"></i> Employees</div>
        <div class="nav-item" onclick="openTab(event, 'salaries')"><i class="fas fa-money-check-alt"></i> Salaries</div>
        <div class="nav-item" onclick="event, openTab(event, 'attendance')"><i class="fas fa-calendar-check"></i> Attendance</div>
    </div>

    <div class="main-content">
        <!-- Summary Dashboard -->
        <div id="dashboard" class="tab-content active">
            <div class="header"><h1>Summary Dashboard</h1></div>
            <div class="card-grid">
                <div class="card"><h3>Total Students</h3><p>128</p></div>
                <div class="card"><h3>Monthly Revenue</h3><p>$12,450</p></div>
                <div class="card"><h3>Net Investment</h3><p>$45,000</p></div>
                <div class="card"><h3>Active Employees</h3><p>14</p></div>
            </div>
            <div class="card" style="height: 200px; display: flex; align-items: center; justify-content: center;">
                <p style="color: #ccc;">[Monthly Performance Chart Placeholder]</p>
            </div>
        </div>

        <!-- Preschool Tab -->
        <div id="preschool" class="tab-content">
            <div class="header"><h1>Preschool Management</h1></div>
            <p>Manage enrollments, classes, and student records here.</p>
        </div>

        <!-- Summer Camp Tab -->
        <div id="summercamp" class="tab-content">
            <div class="header"><h1>Summer Camp</h1></div>
            <p>Track seasonal activities and special camp registrations.</p>
        </div>

        <!-- Investment Tab -->
        <div id="investment" class="tab-content">
            <div class="header"><h1>Investment Tracking</h1></div>
            <table>
                <thead>
                    <tr><th>Date</th><th>Description</th><th>Amount</th><th>Status</th></tr>
                </thead>
                <tbody>
                    <tr><td>2023-10-01</td><td>New Equipment</td><td>$5,000</td><td>Completed</td></tr>
                </tbody>
            </table>
        </div>

        <!-- Expenses Tab -->
        <div id="expenses" class="tab-content">
            <div class="header"><h1>Operating Expenses</h1></div>
            <p>Log and categorize utilities, rent, and supplies.</p>
        </div>

        <!-- Employees Tab -->
        <div id="employees" class="tab-content">
            <div class="header"><h1>Employee Directory</h1></div>
            <table>
                <thead>
                    <tr><th>Name</th><th>Role</th><th>Contact</th></tr>
                </thead>
                <tbody>
                    <tr><td>Jane Doe</td><td>Lead Teacher</td><td>jane@school.com</td></tr>
                    <tr><td>John Smith</td><td>Coordinator</td><td>john@school.com</td></tr>
                </tbody>
            </table>
        </div>

        <!-- Salaries Tab -->
        <div id="salaries" class="tab-content">
            <div class="header"><h1>Salary & Payroll</h1></div>
            <p>Process monthly payroll and view historical disbursements.</p>
        </div>

        <!-- Attendance Tab -->
        <div id="attendance" class="tab-content">
            <div class="header"><h1>Staff & Student Attendance</h1></div>
            <p>Daily check-in logs and monthly reports.</p>
        </div>
    </div>

    <script>
        function openTab(evt, tabName) {
            var i, tabcontent, navitems;
            
            // Hide all tab content
            tabcontent = document.getElementsByClassName("tab-content");
            for (i = 0; i < tabcontent.length; i++) {
                tabcontent[i].style.display = "none";
                tabcontent[i].classList.remove("active");
            }

            // Remove active class from all nav items
            navitems = document.getElementsByClassName("nav-item");
            for (i = 0; i < navitems.length; i++) {
                navitems[i].classList.remove("active");
            }

            // Show the current tab and add active class to button
            document.getElementById(tabName).style.display = "block";
            document.getElementById(tabName).classList.add("active");
            evt.currentTarget.classList.add("active");
        }
    </script>
</body>
</html>
